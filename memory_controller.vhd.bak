-- =============================================================
-- memory_controller.vhd
-- Controlador FSM Moore: copia ROM→RAM y acceso externo
-- Estados: S_IDLE, S_READ_ROM, S_WRITE_RAM, S_READ_RAM, S_DONE
-- =============================================================
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.mem_pkg.all;

entity memory_controller is
  port (
    clk          : in  std_logic;
    rst          : in  std_logic;
    -- Interfaz con ROM
    rom_re       : out std_logic;
    rom_addr     : out addr_word;
    rom_data     : in  data_word;
    -- Interfaz con RAM
    ram_we       : out std_logic;
    ram_re       : out std_logic;
    ram_addr     : out addr_word;
    ram_data_in  : out data_word;
    ram_data_out : in  data_word;
    -- Interfaz externa (activa cuando done='1')
    ext_we       : in  std_logic;
    ext_re       : in  std_logic;
    ext_addr     : in  addr_word;
    ext_data_in  : in  data_word;
    -- Salidas observables
    data_out     : out data_word;
    done         : out std_logic
  );
end entity memory_controller;

architecture rtl of memory_controller is

  -- Definición de estados
  type state_type is (S_IDLE, S_READ_ROM, S_WRITE_RAM, S_READ_RAM, S_DONE);

  signal state        : state_type := S_IDLE;
  signal addr_counter : integer range 0 to MEM_DEPTH-1 := 0;

  -- Registros internos de las señales de control hacia ROM/RAM
  signal s_rom_re      : std_logic := '0';
  signal s_ram_we      : std_logic := '0';
  signal s_ram_re      : std_logic := '0';
  signal s_rom_addr    : addr_word := (others => '0');
  signal s_ram_addr    : addr_word := (others => '0');
  signal s_ram_data_in : data_word := (others => '0');
  signal s_done        : std_logic := '0';

  -- Captura del dato ROM para pipeline de un ciclo
  signal rom_data_reg  : data_word := (others => '0');

begin

  -- -------------------------------------------------------
  -- Proceso secuencial: registro de estado y contador
  -- -------------------------------------------------------
  process(clk)
  begin
    if rising_edge(clk) then
      if rst = '1' then
        -- Reset síncrono: vuelve a IDLE
        state        <= S_IDLE;
        addr_counter <= 0;
        s_done       <= '0';
        clear_control_signals(s_rom_re, s_ram_we, s_ram_re);
        s_rom_addr    <= (others => '0');
        s_ram_addr    <= (others => '0');
        s_ram_data_in <= (others => '0');
        rom_data_reg  <= (others => '0');

      else
        -- ------------------------------------------------
        -- Lógica de transición y salidas (Moore combinado)
        -- ------------------------------------------------
        case state is

          -- Estado IDLE: limpia todo y arranca
          when S_IDLE =>
            clear_control_signals(s_rom_re, s_ram_we, s_ram_re);
            addr_counter  <= 0;
            s_done        <= '0';
            state         <= S_READ_ROM;

          -- Estado READ_ROM: activa lectura de ROM en addr_counter
          when S_READ_ROM =>
            clear_control_signals(s_rom_re, s_ram_we, s_ram_re);
            s_rom_re   <= '1';
            s_rom_addr <= std_logic_vector(to_unsigned(addr_counter, ADDR_WIDTH));
            -- Captura el dato ROM que llegará en el próximo ciclo
            -- (la ROM es síncrona: dato válido un ciclo después)
            rom_data_reg <= rom_data;
            state <= S_WRITE_RAM;

          -- Estado WRITE_RAM: escribe dato capturado en RAM
          when S_WRITE_RAM =>
            clear_control_signals(s_rom_re, s_ram_we, s_ram_re);
            s_ram_we      <= '1';
            s_ram_addr    <= std_logic_vector(to_unsigned(addr_counter, ADDR_WIDTH));
            s_ram_data_in <= rom_data_reg;  -- dato capturado de ROM
            state         <= S_READ_RAM;

          -- Estado READ_RAM: verifica lectura; avanza o termina
          when S_READ_RAM =>
            clear_control_signals(s_rom_re, s_ram_we, s_ram_re);
            s_ram_re   <= '1';
            s_ram_addr <= std_logic_vector(to_unsigned(addr_counter, ADDR_WIDTH));
            if addr_counter = MEM_DEPTH - 1 then
              state <= S_DONE;
            else
              addr_counter <= addr_counter + 1;
              state        <= S_READ_ROM;
            end if;

          -- Estado DONE: copia completa, acceso externo habilitado
          when S_DONE =>
            s_done <= '1';
            -- Enruta señales externas directamente a RAM
            s_ram_we      <= ext_we;
            s_ram_re      <= ext_re;
            s_ram_addr    <= ext_addr;
            s_ram_data_in <= ext_data_in;
            -- ROM no se usa más en este estado
            s_rom_re   <= '0';
            s_rom_addr <= (others => '0');
            -- Reset puede sacar del estado DONE (manejado arriba)

          when others =>
            state <= S_IDLE;

        end case;
      end if;
    end if;
  end process;

  -- -------------------------------------------------------
  -- Asignación de salidas hacia ROM y RAM
  -- -------------------------------------------------------
  rom_re      <= s_rom_re;
  rom_addr    <= s_rom_addr;
  ram_we      <= s_ram_we;
  ram_re      <= s_ram_re;
  ram_addr    <= s_ram_addr;
  ram_data_in <= s_ram_data_in;
  done        <= s_done;

  -- data_out muestra RAM durante READ_RAM y S_DONE
  -- En S_DONE refleja lo que la RAM devuelve por acceso externo
  data_out <= ram_data_out;

end architecture rtl;